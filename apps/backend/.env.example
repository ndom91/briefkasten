NODE_ENV=development

# Port the Hono server listens on (compose maps ${PORT:-8000})
PORT=8000

# Number of background queue workers (screenshot / feed-fetch jobs)
QUEUE_WORKERS=2

# Auth - Same values as the web app Better Auth config
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Object Store
BUCKET_NAME=
BUCKET_ACCESS_KEY=
BUCKET_SECRET_KEY=
BUCKET_URL=
BUCKET_PUBLIC_URL=

# Object Store - RustFS Example (local dev via docker-compose.storage.yml)
# BUCKET_NAME=briefkasten
# BUCKET_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# BUCKET_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# BUCKET_URL="http://rustfs:9000/${BUCKET_NAME}"
# BUCKET_PUBLIC_URL="http://localhost:9000/${BUCKET_NAME}"

# Prisma - Default docker-compose.storage
DATABASE_URL=postgres://postgres:postgres@database:5432/briefkasten
