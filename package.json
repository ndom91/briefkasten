{
  "name": "root",
  "author": "ndom91 <yo@ndo.dev>",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "repository": "https://github.com/ndom91/sveltekasten.git",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm run --parallel --filter sveltekasten-web --filter sveltekasten-backend dev",
    "dev:web": "pnpm run --dir apps/web dev",
    "dev:api": "pnpm run --dir apps/backend dev",
    "build": "pnpm run --parallel build",
    "start": "pnpm run --parallel start",
    "format": "biome format --write apps/*/src/**/*.{svelte,ts}",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check --write .",
    "db:generate": "pnpm run --parallel db:generate",
    "db:studio": "pnpm run --filter sveltekasten-web db:studio",
    "db:push": "pnpm run --filter sveltekasten-web db:push",
    "db:deploy": "pnpm run --filter sveltekasten-web db:deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "jiti": "^2.6.1",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
